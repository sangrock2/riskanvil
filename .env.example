# ===========================================
# Stock-AI Environment Variables Template
# ===========================================
# Copy this file to .env and fill in the values
# ===========================================

# =====================
# Backend (Spring Boot)
# =====================

# Render Web Service port (Render injects PORT automatically)
PORT=8080

# PostgreSQL Database (local/docker-compose default)
DB_URL=jdbc:postgresql://localhost:5432/stock_ai
# Alternative to DB_URL (host:port form for private network)
DB_HOSTPORT=localhost:5432
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password
DB_DRIVER_CLASS_NAME=org.postgresql.Driver

# Managed PostgreSQL (권장: SPRING_PROFILES_ACTIVE=prod,postgres)
# DB_URL=jdbc:postgresql://<host>:5432/stock_ai
# (앱이 postgresql://... 또는 postgres://... 입력을 자동 보정하지만, 운영에서는 jdbc:postgresql://... 권장)
# DB_DRIVER_CLASS_NAME=org.postgresql.Driver
# JPA_DDL_AUTO=validate
# FLYWAY_ENABLED=true
# FLYWAY_BASELINE_VERSION=2
POSTGRES_DB=stock_ai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# JWT Authentication
JWT_SECRET=your-jwt-secret-key-min-32-characters-long
JWT_EXP_MINUTES=15
REFRESH_TOKEN_PEPPER=required-extra-secret-for-refresh-token-hashing-in-prod
REFRESH_TOKEN_CLEANUP_CRON=0 */30 * * * *
REFRESH_TOKEN_COOKIE_SECURE=true
# Use None only when frontend and backend are truly cross-site. For same-site subdomains, prefer Lax.
REFRESH_TOKEN_COOKIE_SAME_SITE=Lax

# AI Service
AI_BASE_URL=http://localhost:8000
# Alternative to AI_BASE_URL (host:port form for private network)
AI_SERVICE_HOSTPORT=localhost:8000
AI_INTERNAL_SERVICE_TOKEN=generate-a-long-random-shared-token-for-backend-and-ai
AI_CLIENT_TIMEOUT_DEFAULT_SECONDS=30
AI_CLIENT_TIMEOUT_REPORT_SECONDS=180
AI_CLIENT_RETRY_ATTEMPTS=2
AI_CLIENT_RETRY_REPORT_ATTEMPTS=0
AI_CLIENT_RETRY_BACKOFF_MILLIS=200
AI_CLIENT_RETRY_MAX_BACKOFF_MILLIS=2000
TOTP_ENCRYPTION_KEY=generate-a-dedicated-32-byte-or-longer-secret

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Spring Profile (dev, prod, postgres)
SPRING_PROFILES_ACTIVE=dev,postgres
JPA_DDL_AUTO=
FLYWAY_ENABLED=
FLYWAY_BASELINE_VERSION=
SPRING_CACHE_TYPE=redis
APP_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:3000,http://localhost:5173

# =====================
# Docker Compose
# =====================

# PostgreSQL Container
GRAFANA_USER=your_grafana_admin_user
GRAFANA_PASSWORD=your_grafana_admin_password

# =====================
# AI Service (Python)
# =====================

# Optional: Local LLM (Ollama)
LLM_PROVIDER=openai
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# =====================
# Error Monitoring (Sentry) - Optional
# =====================
# Get DSN from https://sentry.io (create a project per service)
# Leave empty to disable Sentry

# Backend (Spring Boot)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Frontend (Vite) - prefix with VITE_
VITE_SENTRY_DSN=
VITE_API_PROXY_TARGET=http://localhost:8080
# Production API base URL (e.g. https://stock-ai-backend.onrender.com)
VITE_API_BASE_URL=
# Internal architecture map UI. Keep false for public builds.
VITE_ENABLE_SYSTEM_MAP=false
# Service Worker is off by default to avoid stale deploy caches.
VITE_ENABLE_SERVICE_WORKER=false
# Optional: override WebSocket endpoint (default uses current host /ws/quotes)
# Supports: wss://..., ws://..., https://... (auto-converted to wss://...)
VITE_WS_URL=
# Legacy compatibility (kept during migration window)
REACT_APP_SENTRY_DSN=
REACT_APP_API_BASE_URL=
REACT_APP_WS_URL=

# AI Service (FastAPI)
# SENTRY_DSN= (shared with backend or use separate project)
