# ===========================================
# Stock-AI Environment Variables Template
# ===========================================
# Copy this file to .env and fill in the values
# ===========================================

# =====================
# Backend (Spring Boot)
# =====================

# Render Web Service port (Render injects PORT automatically)
PORT=8080

# MySQL Database
DB_URL=jdbc:mysql://localhost:3306/stock_ai?useSSL=false&serverTimezone=Asia/Seoul&characterEncoding=UTF-8
# Alternative to DB_URL (host:port form for private network)
DB_HOSTPORT=localhost:3306
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# JWT Authentication
JWT_SECRET=your-jwt-secret-key-min-32-characters-long
JWT_EXP_MINUTES=60
REFRESH_TOKEN_PEPPER=optional-extra-secret-for-refresh-token-hashing
REFRESH_TOKEN_CLEANUP_CRON=0 */30 * * * *

# AI Service
AI_BASE_URL=http://localhost:8000
# Alternative to AI_BASE_URL (host:port form for private network)
AI_SERVICE_HOSTPORT=localhost:8000
AI_CLIENT_TIMEOUT_DEFAULT_SECONDS=30
AI_CLIENT_TIMEOUT_REPORT_SECONDS=180
AI_CLIENT_RETRY_ATTEMPTS=2
AI_CLIENT_RETRY_REPORT_ATTEMPTS=0
AI_CLIENT_RETRY_BACKOFF_MILLIS=200
AI_CLIENT_RETRY_MAX_BACKOFF_MILLIS=2000

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Spring Profile (dev, prod)
SPRING_PROFILES_ACTIVE=dev
APP_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:3000,http://localhost:5173

# =====================
# Docker Compose
# =====================

# MySQL Container
MYSQL_ROOT_PASSWORD=your_root_password
MYSQL_DATABASE=stock_ai
MYSQL_USER=your_db_username
MYSQL_PASSWORD=your_db_password

# =====================
# AI Service (Python)
# =====================

# Optional: Local LLM (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# =====================
# Error Monitoring (Sentry) - Optional
# =====================
# Get DSN from https://sentry.io (create a project per service)
# Leave empty to disable Sentry

# Backend (Spring Boot)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Frontend (Vite) - prefix with VITE_
VITE_SENTRY_DSN=
VITE_API_PROXY_TARGET=http://localhost:8080
# Production API base URL (e.g. https://stock-ai-backend.onrender.com)
VITE_API_BASE_URL=
# Optional: override WebSocket endpoint (default uses current host /ws/quotes)
# Supports: wss://..., ws://..., https://... (auto-converted to wss://...)
VITE_WS_URL=
# Legacy compatibility (kept during migration window)
REACT_APP_SENTRY_DSN=
REACT_APP_API_BASE_URL=
REACT_APP_WS_URL=

# AI Service (FastAPI)
# SENTRY_DSN= (shared with backend or use separate project)
