{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@sentry/react": "^8.0.0",
    "@tanstack/react-query": "^5.90.20",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^13.5.0",
    "i18next": "^25.8.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-i18next": "^16.5.4",
    "react-router-dom": "^7.11.0",
    "recharts": "^3.7.0",
    "web-vitals": "^2.1.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "jsdom": "^26.1.0",
    "vite": "^5.4.11",
    "vitest": "^2.1.9"
  },
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 3000",
    "test": "vitest run --config vitest.config.cjs --pool=threads --poolOptions.threads.singleThread=true",
    "test:watch": "vitest --config vitest.config.cjs --pool=threads --poolOptions.threads.singleThread=true",
    "system-map:generate": "node ../scripts/generate_system_map_data.js",
    "openapi:generate": "python ../scripts/generate_typed_client.py",
    "openapi:check": "npm run openapi:generate && git diff --exit-code src/api/generated"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
